# Copy to /etc/foreigngsm-bridge.env on PBX.
# Must be readable by user asterisk (FreePBX runs System() as asterisk): e.g.
#   chown root:asterisk /etc/foreigngsm-bridge.env && chmod 640 /etc/foreigngsm-bridge.env
# chmod 600 root-only breaks MainSMS presignal (script exits 0 but sends nothing).
# Used by foreigngsm-presignal-sms-wait.sh and foreigngsm-presignal-sms.sh.example
#
# Presignal = MainSMS.ru HTTP API (GSM шлюз для SMS не используется).

MAINSMS_URL='https://mainsms.ru/api/message/send'
MAINSMS_PROJECT='spartak-it'
# Секрет: только на сервере, не коммитить.
MAINSMS_APIKEY='REPLACE_WITH_PROJECT_API_KEY'
# Получатель пресигнала (F3 / телефон моста): только цифры или +E.164
DEST_MSISDN='+79111580016'
# Таймаут HTTP (сек); на старых PBX лучше 10–15 (curl к mainsms.ru)
MAINSMS_HTTP_MAXTIME='10'
# Строка в лог на каждый вызов (user asterisk должен иметь право писать в каталог)
# PRESIGNAL_AUDIT_LOG='/var/log/asterisk/foreigngsm-presignal.log'
#
# Если в кабинете MainSMS статус «Не доставлено», а audit на АТС показывает http=200:
# это отказ/задержка у оператора или маршрута MainSMS — пишите support@mainsms.ru с ID
# сообщения и просите код/причину от SMSC. Скрипт и Asterisk здесь ни при чём.
# 8 символов A–Z / a–z / 0–9 — тот же токен, что в приложении (настройка presignal token)
PRESIGNAL_SMS_TOKEN='K9M2FX7Q'
# RU: 89… (11 цифр) → 79… для API; no — не трогать префикс
# RU_LEAD8_TO7='yes'

# --- goip-relay (UDP→HTTP) на шлюз: отдельный config, не presignal ---
# GOIP_* здесь больше не нужны для Asterisk presignal.
